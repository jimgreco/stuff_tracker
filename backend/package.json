{
  "name": "stuff-tracker-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "npm run db:migrate",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "node scripts/migrate.cjs",
    "db:backup": "node scripts/backup-db.cjs",
    "db:backup:check": "node scripts/check-backup-freshness.cjs",
    "db:hardening:check": "node scripts/check-db-runtime-hardening.cjs",
    "smoke:deploy": "node scripts/smoke-deploy.cjs",
    "storage:s3:check": "node scripts/check-s3-hardening.cjs",
    "storage:cleanup": "node scripts/cleanup-orphaned-uploads.cjs",
    "test": "node --require tsx/cjs --test test/*.test.ts"
  },
  "dependencies": {
    "@apple/app-store-server-library": "^3.1.0",
    "@aws-sdk/client-s3": "^3.1063.0",
    "@aws-sdk/s3-request-presigner": "^3.1063.0",
    "apple-signin-auth": "^2.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.7.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.11.0",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3"
  }
}
